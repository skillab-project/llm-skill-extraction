services:
  app:
    build: .
    image: ${DOCKER_REG}${DOCKER_REPO}${APP_NAME}:${DOCKER_TAG}
    container_name: upskilling-recommender-app
    
    depends_on:
      db:
        condition: service_healthy
    ports:
      - "8888:8080"
    networks:
      - upskilling-recommender-network
    env_file:
      - .env
    labels:
      io.portainer.accesscontrol.teams: skillab-all
      
      
networks:
  upskilling-recommender-network:
    driver: bridge

volumes:
  postgres-data:
    driver: local
